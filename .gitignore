# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# kullanici tarafindan yuklenen urun fotograflari (disk-lokal, ileride R2'ye tasinacak)
/public/uploads

# Claude Code yerel oturum/ayar dosyalari (paylasilan repoya girmez)
/.claude

# satis/pazarlama ozel calismalari (repoya girmez)
/docs/satis

# demo seed fotograflari: binary'ler repoya girmez, metin kayitlari (liste + atif)
# kalir - gorseller indir-commons.js + secimleri-kopyala.js ile yeniden uretilebilir.
/scripts/demo-veri/fotograflar/*
!/scripts/demo-veri/fotograflar/LISTE.md
!/scripts/demo-veri/fotograflar/varsayilan/
/scripts/demo-veri/fotograflar/varsayilan/*
!/scripts/demo-veri/fotograflar/varsayilan/ATIF.json
