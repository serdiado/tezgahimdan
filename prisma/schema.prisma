// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HaftaGunu {
  Pazartesi
  Sali
  Carsamba
  Persembe
  Cuma
  Cumartesi
  // Model adiyla (Pazar/market) karismasin diye "PazarGunu" (Sunday).
  PazarGunu
}

// Pazarlar sadece admin tarafindan, belediyeyle yapilan anlasma sonucu tek tek
// elle olusturulur (Turkiye geneli il/ilce referans verisi YOK - 973 ilcenin
// neredeyse hicbirinde pazar kurulmayacagi icin gereksiz). il/ilce/semt serbest
// metin, googleHaritaLinki zorunlu (yol tarifi icin - harita gomulmez, sadece
// yeni sekmede acilan bir link).
model Pazar {
  id                String    @id @default(uuid())
  ad                String
  // Herkese acik pazar sayfasinin URL'i (/pazar/[slug]) - Magaza.slug ile ayni
  // desen. Migration'da mevcut pazarlara ad'dan turetilerek backfill edildi
  // (2026-07-09 pazar_slug migration'i, cakismada -2/-3 eki).
  slug              String    @unique
  il                String
  ilce              String
  semt              String?
  googleHaritaLinki String
  // Icerik/raporlama alanlari (2026-07-09) - hicbiri islevsel akisi etkilemez,
  // hepsi opsiyonel (mevcut pazarlar geriye donuk NULL kalir).
  belediyeAdi    String? // ulusal buyume hedefi: hangi belediyeye ait, ileride raporlama/coklu-belediye ayrimi icin
  aciklama       String? @db.Text // vitrin/anasayfada gosterilecek kisa tanitim metni
  // Pazar sayfasi hero'su (2026-07-10): belediye logosu beyaz cip icinde,
  // kapak fotografi hero arka plani (yari saydam gradyan overlay ile) olur.
  // Ikisi de bos birakilabilir - o zaman duz gradyan gorunum aynen kalir.
  // Yukleme /api/admin/pazar-gorsel ile (site-icerik gorsel deseni).
  // belediyeLogoLink: doluysa logo cipi tiklanabilir olur (belediye web sitesi).
  belediyeLogoUrl  String?
  belediyeLogoLink String?
  kapakFotoUrl     String?
  sorumluAdi     String? // pazar sorumlusu (PLAN.md SS7'deki gelecek rolun temeli) - admin ic referansi
  sorumluTelefon String?
  // baslangic*: pazarin acilis (ceza esigi) ani. sifirlama*: pazarin GERCEK/ilan
  // edilen kapanis ani (UI'da "Kapanis Saati" - eskiden "Sifirlama Saati").
  // Ikisi FARKLI an: baslangic "kim cezali"yi belirler, kapanis SADECE ilan
  // edilen saat + hatirlatma/islem-sonu hesaplarinin CAPA noktasidir - kuyrugu
  // artik DOGRUDAN TETIKLEMEZ (bkz. islemSon*).
  baslangicGunu  HaftaGunu @default(Carsamba)
  baslangicSaati DateTime  @default(dbgenerated("'09:00:00'::time")) @db.Time
  sifirlamaGunu  HaftaGunu
  sifirlamaSaati DateTime  @db.Time
  // islemSon*: saticinin en son "Sattim/Gelmedi" isaretleyebilecegi an - otomatik
  // "gelmedi" cezasinin GERCEKTEN tetiklendigi an budur (bkz. rezervasyon.ts
  // urunSifirla). hatirlatma*: saticiya "isaretlemeyi unutma" bildiriminin
  // gittigi an. IKISI DE NULL olabilir (mevcut pazarlar + yeni pazar formunda
  // bos birakilirsa) - bu durumda kod eski sabit varsayimlara duser (islemSon
  // -> kapanis gunu + gece yarisi, hatirlatma -> kapanis + 1 saat, bkz.
  // pazar-haftasi.ts). Gece pazarlari (kapanis 01:00-02:00 gibi) icin bu
  // varsayimlar YANLIS olabilir - kullanici KARARI: hepsi manuel ayarlanabilir
  // olmali, kapanis gununden FARKLI bir gune bile denk gelebilir (ör. kapanis
  // Carsamba 01:00 ise islemSonGunu Carsamba, saati 10:00 gibi olabilir).
  islemSonGunu   HaftaGunu?
  islemSonSaati  DateTime?  @db.Time
  hatirlatmaGunu HaftaGunu?
  hatirlatmaSaati DateTime? @db.Time
  saatDilimi     String    @default("Europe/Istanbul")
  // Pasif (aktifMi=false) oldugunda: (1) bagli magazalar vitrinde/anasayfada
  // GORUNMEZ (getMagazaBySlug + anasayfa sorgusu pazar.aktifMi filtreler),
  // (2) o pazardaki saticilar panele giremez (bkz. src/app/panel/layout.tsx),
  // (3) yeni magaza acilisinda secilemez. Kalici silme YOK - sadece bu bayrak.
  aktifMi        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  magazalar     Magaza[]
  sifirlamalar  PazarSifirlama[]
  hatirlatmalar PazarHatirlatma[]
}

// Idempotency + audit: her (pazar, pazarHaftasi) icin bir sifirlama calismasi kaydi.
// Unique (pazarId, pazarHaftasi) - "bu hafta yapildi mi" takibi.
model PazarSifirlama {
  id            String   @id @default(uuid())
  pazar         Pazar    @relation(fields: [pazarId], references: [id])
  pazarId       String
  pazarHaftasi  DateTime @db.Date
  calismaZamani DateTime @default(now())
  etkilenenSayi Int      @default(0)

  @@unique([pazarId, pazarHaftasi])
}

// PazarSifirlama ile AYNI idempotency deseni (unique pazarId+pazarHaftasi), ama
// DO NOTHING ile tek seferlik "bu hafta hatirlatma gonderildi mi" bayragi -
// DO UPDATE (sayac biriktirme) YOK, cunku burada tekrar sayilacak bir "etkilenen"
// yok, sadece "gonderildi mi" sorusu var (bkz. rezervasyon.ts pazarHatirlatmalariGonder).
model PazarHatirlatma {
  id               String   @id @default(uuid())
  pazar            Pazar    @relation(fields: [pazarId], references: [id])
  pazarId          String
  pazarHaftasi     DateTime @db.Date
  gonderilmeZamani DateTime @default(now())

  @@unique([pazarId, pazarHaftasi])
}

// PLAN.md SS7: "pazar_sorumlusu" rolu ileride eklenecek, simdilik kapsam disi.
enum KullaniciRolu {
  satici
  alici
  admin
}

model Kullanici {
  id        String        @id @default(uuid())
  ad        String
  telefon   String?       @unique
  rol       KullaniciRolu @default(alici)
  // Admin moderasyon bayragi (Magaza.gizliMi ile AYNI "fren pedali" desen):
  // giris ve gecmis erisimi ETKILENMEZ, sadece YENI aksiyonlar (rezervasyon
  // olusturma, magaza acma, degerlendirme/yorum birakma, sikayet olusturma)
  // engellenir. Enforcement noktalari icin bkz. src/lib/yetki.ts
  // kullaniciYasakliMi().
  yasakliMi Boolean       @default(false)
  // Gelmedi serisinin baslangic noktasi: seri hesabi SADECE bu tarihten SONRA
  // olusturulmus kayitlari kapsar (kayitlar silinmez, sadece filtrelenir). IKI
  // yazari var (2026-07-10): (1) admin affi (kullanici-guvenilirlik-sifirla),
  // (2) otomatik yasak baslangici - seri dolunca yasakla birlikte sayac da
  // sifirlanir, yasak bitince alici temiz sayfayla doner (bkz.
  // src/lib/rezervasyon.ts gelmediYasagiKontrolEt,
  // docs/mimari/guvenilirlik-sistemi.md).
  guvenilirlikSifirlamaTarihi DateTime?
  // Gelmedi yasagi (2026-07-10): UST USTE esik kadar "gelmedi" biriktiren alici
  // bu ana kadar YENI rezervasyon olusturamaz (yasak baslarken bekleyen
  // rezervasyonlari da otomatik iptal edilir - bkz. yasakSupurmesi). Gecmis
  // tarih = yasak yok demektir (ayrica temizlik gerektirmez); satici "gelmedi"
  // geri alirsa veya admin af verirse null'lanir.
  rezervasyonYasagiBitisi DateTime?
  createdAt DateTime      @default(now())

  // E-posta/Google girisi icin: ikisi de opsiyonel (telefon+SMS ile gelen kullanicida
  // olmayabilir). sifreHash null ise hesap sadece Google ile acilmis demektir.
  // emailVerified: Google dogruladiysa dolar; sifre ile kayitta bos kalir (dogrulama
  // akisi yok), Google hesap eslestirmesinde bu alan guvenlik kontrolu olarak kullanilir.
  email         String?   @unique
  emailVerified DateTime?
  sifreHash     String?

  magazalar               Magaza[]
  rezervasyonlar          Rezervasyon[]
  durumGecmisi            DurumGecmisi[]
  sikayetler              Sikayet[]
  urunFavorileri          UrunFavori[]
  bildirimler             Bildirim[]
  magazaTakipleri         MagazaTakip[]
  degerlendirmeler        Degerlendirme[]
  magazaDegerlendirmeleri MagazaDegerlendirme[]
  duyurular               Duyuru[]
}

model Kategori {
  id        String   @id @default(uuid())
  ad        String
  // Kalici silme yok (PLAN.md "hicbir kayit kalici silinmez"): kullanimda
  // degilse (hicbir Urun.kategoriId bu id'yi isaret etmiyorsa) admin soft-delete
  // eder, "Geri Getir" ile geri doner. Kullanimdaysa kaldirma engellenir.
  silindiMi Boolean  @default(false)
  createdAt DateTime @default(now())

  urunler Urun[]
}

model Magaza {
  id         String    @id @default(uuid())
  sahip      Kullanici @relation(fields: [sahipId], references: [id])
  sahipId    String
  ad         String
  slug       String    @unique
  aciklama   String?
  // Basit "magaza olustur" akisinda toplanmiyor (sadece ad+slug); sonradan
  // magaza ayarlarindan doldurulur. Bos string yerine gercek NULL taniyoruz.
  whatsappNo String?
  // Serbest metin tarif ("12", "A Blok 5", "giristen 3. sagdaki tezgah") - sayiyla
  // sinirlanmaz, max 100 karakter SADECE API/server action katmaninda kontrol edilir
  // (puan 1-5 gibi diger validasyonlar da DB'de degil route'ta kisitlaniyor).
  tezgahBilgisi String?
  // Saticinin KENDI magazasi icin yukledigi TEK fotograf (tezgahinin fotografi ya da
  // elle cizdigi kroki) - admin-yonetimli ortak pazar haritasi DEGIL, urunEkle() ile
  // ayni upload altyapisinin tek-fotograf versiyonu (bkz. src/lib/magaza-kroki.ts).
  krokiFotoUrl  String?
  // Sosyal medya linkleri (2026-07-10): sabit 3 platform, hepsi opsiyonel.
  // Satici Ayarlar'da "ekle" akisiyla birini secip link girer - bos olan
  // hic gosterilmez (hero'da ikon cikmaz). JSON/dinamik liste yerine ayri
  // alanlar tercih edildi: bu semadaki (whatsappNo, belediyeAdi vb.) mevcut
  // "her alan kendi adiyla" desenine uyar, sorgulanmasi/dogrulanmasi basit kalir.
  instagramUrl String?
  facebookUrl  String?
  tiktokUrl    String?
  pazar      Pazar     @relation(fields: [pazarId], references: [id])
  pazarId    String
  silindiMi  Boolean   @default(false)
  // Admin moderasyon bayragi: magaza vitrinsen GIZLENIR ama sahibinin erisimi ve
  // tek-aktif-magaza kisiti bozulmaz (silindiMi'den ayri tutulmasinin nedeni:
  // silindiMi getOwnMagaza'yi da filtreler ve WHERE silindiMi=false unique index'i
  // yuzunden gizlenen satici ikinci magaza acabilirdi). Self-servis onboarding'in
  // "fren pedali": herkes aninda satici olur, admin gerekirse tek bayrakla gizler.
  gizliMi    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  urunler                 Urun[]
  sikayetler              Sikayet[]
  takipciler              MagazaTakip[]
  degerlendirmeler        MagazaDegerlendirme[]
}

enum UrunDurumu {
  sergide
  doldu
  satildi
}

model Urun {
  id          String     @id @default(uuid())
  magaza      Magaza     @relation(fields: [magazaId], references: [id])
  magazaId    String
  kategori    Kategori   @relation(fields: [kategoriId], references: [id])
  kategoriId  String
  baslik      String
  aciklama    String?
  fiyat       Decimal    @db.Decimal(10, 2)
  stokAdedi   Int        @default(1)
  fotograflar String[]   @default([])
  durum       UrunDurumu @default(sergide)
  silindiMi   Boolean    @default(false)
  createdAt   DateTime   @default(now())

  rezervasyonlar   Rezervasyon[]
  sikayetler       Sikayet[]
  favoriler        UrunFavori[]
  bildirimler      Bildirim[]
  degerlendirmeler Degerlendirme[]
}

enum RezervasyonTipi {
  aktif
  yedek
}

enum RezervasyonDurumu {
  bekliyor
  satildi
  gelmedi
  iptal
}

model Rezervasyon {
  id                 String            @id @default(uuid())
  urun               Urun              @relation(fields: [urunId], references: [id])
  urunId             String
  alici              Kullanici         @relation(fields: [aliciId], references: [id])
  aliciId            String
  tip                RezervasyonTipi
  siraNo             Int
  durum              RezervasyonDurumu @default(bekliyor)
  rezervKodu         String            @unique
  pazarHaftasi       DateTime          @db.Date
  // Kayit aktife her gectiginde (olusturmada aktif atanma / yedekten yukselme /
  // geri alma) set edilir. Sifirlama cezasi: aktifOlmaZamani < pazarBaslangicAni
  // olan (yani pazar baslangicinda zaten aktif olan) ve hala bekleyenler no-show.
  aktifOlmaZamani    DateTime?
  // Sifirlamada temizlenen kuyruga birakilan iz (gonderim YOK, Faz 2). Urun
  // tekrar acilinca eski uyelere "oncelikli davet" bildirimi icin.
  bildirimGonderildi Boolean           @default(false)
  bildirimKanali     String?
  // 2026-07-09 karari: aktif-since-start + isaretlenmemis rezervasyonlar ARTIK
  // OTOMATIK "gelmedi" olmuyor (alici asla satici ihmalinden cezalanmaz) -
  // bunun yerine satici panele girene VE isaretleyene kadar bekler (bkz.
  // src/app/panel/layout.tsx). Bu bayrak, isaretlenmeden 3 gun gecerse
  // admin'e giden tek seferlik uyarinin idempotency'sini saglar (saticiIhmalUyarilariGonder).
  saticiIhmalUyarisiGonderildi Boolean @default(false)
  createdAt          DateTime          @default(now())
}

// Genel amacli audit/istatistik log'u; tek bir tabloya baglanmaz (varlikTuru + varlikId ile
// Urun/Magaza/Rezervasyon vb. herhangi bir kaydi isaret edebilir).
model DurumGecmisi {
  id          String     @id @default(uuid())
  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId String?
  varlikTuru  String
  varlikId    String
  olay        String
  // Admin'in kayda ekledigi kisa serbest not (ör. Anlasmazliklar sayfasinda bir
  // reddin arka planini aciklamak icin). Sadece anlasmazlik triyajinda
  // kullaniliyor ama tabloya ozel olmasi gerekmiyor - genel amacli DurumGecmisi
  // ile tutarli, digerlerini etkilemez (varsayilan null).
  not         String?
  createdAt   DateTime   @default(now())
}

enum SikayetDurumu {
  bekliyor
  inceleniyor
  cozuldu
  reddedildi
}

// hedefUrunId / hedefMagazaId: tam olarak biri dolu olmali (uygulama katmaninda kontrol edilir).
model Sikayet {
  id            String        @id @default(uuid())
  sikayetci     Kullanici     @relation(fields: [sikayetciId], references: [id])
  sikayetciId   String
  hedefUrun     Urun?         @relation(fields: [hedefUrunId], references: [id])
  hedefUrunId   String?
  hedefMagaza   Magaza?       @relation(fields: [hedefMagazaId], references: [id])
  hedefMagazaId String?
  sebep         String
  durum         SikayetDurumu @default(bekliyor)
  // Admin'in sikayetciye yonelik kisa yaniti - opsiyonel, /sikayetlerim'de
  // sikayetcinin kendisine gosterilir. AP-6 "salt okunur triyaj" karariyla
  // celismez: durum tek yonlu ilerlemeye devam eder, bu sadece ek bir alan.
  yanit         String?
  createdAt     DateTime      @default(now())
}

// Kalp/begeni (begeniMi) ve favori/takip (takipMi) AYNI (kullanici,urun) satirinda
// iki bagimsiz bayrak - ikisi de ayni sekle sahip oldugu icin iki ayri tablo yerine
// tek tablo (PLAN.md "hicbir kayit kalici silinmez" ilkesiyle tutarli: geri alma =
// ilgili bayragi false yapmak, satir hic silinmez).
model UrunFavori {
  id          String    @id @default(uuid())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId String
  urun        Urun      @relation(fields: [urunId], references: [id])
  urunId      String
  // Kalp/begeni: herkese acik sayilir, bildirim tetiklemez.
  begeniMi    Boolean   @default(false)
  // Favori/takip: bildirim aboneligi (rezervasyon.ts'teki aktif-katman
  // hareketlerinde bildirimGonderTakipcilere() bu bayragi okur).
  takipMi     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([kullaniciId, urunId])
}

// Site-ici bildirim (Faz 2'de WhatsApp/SMS kanaliyla degistirilebilir/genisletilebilir
// altyapi - Rezervasyon.bildirimKanali/bildirimGonderildi'nin urun-takip karsiligi).
model Bildirim {
  id          String    @id @default(uuid())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId String
  // Opsiyonel: takip/favori kaynakli bildirimler (bildirimGonderTakipcilere vb.)
  // hep dolu gonderir, ama urune bagli olmayan genel bildirimler (bkz.
  // bildirimGonderKullaniciya) urunId'siz gonderir.
  urun        Urun?     @relation(fields: [urunId], references: [id])
  urunId      String?
  // urunId bos oldugunda /bildirimlerim'in yonlendirecegi opsiyonel hedef (ör.
  // sikayet sonucu bildirimi -> "/sikayetlerim"). Bos bildirim tipi (ör. toplu
  // duyuru) icin de bos kalir - o zaman kart TIKLANAMAZ (2026-07-08: onceden
  // HER urunId'siz bildirim /sikayetlerim'e gidiyordu, duyuru eklenince bu
  // yanlis hedefe tiklamaya donustu - kullanici testinde bulundu).
  hedefYolu   String?
  // Duyuru pointer'i (2026-07-10): admin editoryal duyurusu yayinlaninca hedef
  // kitleye bu alanla Bildirim uretilir - govde Duyuru'da yasar, Bildirim sadece
  // baslik + pointer. /bildirimlerim href cozumu urunId'den sonra bunu kontrol
  // eder (-> /duyuru/{id}). Okunma istatistigi (Duyuru admin sayfasi) bu FK
  // uzerinden sayilir. urunId ile karsilikli DISLAYICI (biri doluysa oteki bos).
  duyuru      Duyuru?   @relation(fields: [duyuruId], references: [id])
  duyuruId    String?
  mesaj       String
  okunduMu    Boolean   @default(false)
  // Kullanici kendi bildirimini listeden temizleyince set edilir (2026-07-10).
  // Kalici silme YOK (proje ilkesi) - soft-delete: DB'de durur, /bildirimlerim
  // ve SiteHeader rozet sorgulari silindiMi=false filtreler. Admin moderasyonu
  // degil (o gizliMi deseni) - burada kaydin SAHIBI kendi gorunumunden kaldirir.
  silindiMi   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([kullaniciId, okunduMu])
}

// Editoryal duyuru (2026-07-10): admin tarafindan yazilan, UZUN icerik
// tasiyabilen "yeni isleyis / modul / egitim" gibi bildirimler. Kisa+varlik-bagli
// islem bildirimlerinden (Bildirim tablosu) AYRI tutulur: govde burada yasar,
// yayinlaninca hedef kitleye Bildirim pointer'lari uretilir (Bildirim.duyuruId).
// Tiklaninca /duyuru/[id] detay sayfasi acilir. Kutsal kural admin'de gecerli
// degil (CMS derinligi hedefi - bkz. docs/mimari). Detay: docs/mimari/bildirim-sistemi.md.
enum DuyuruTuru {
  bilgi
  egitim
  uyari
}

model Duyuru {
  id         String     @id @default(uuid())
  baslik     String
  // Markdown (2026-07-10): react-markdown ile render edilir - baglanti, kalin,
  // baslik, liste, gomulu gorsel. Ham HTML render EDILMEZ (XSS guvenli).
  govde      String     @db.Text
  gorselUrl  String?
  // Detay sayfasinin altinda cikan opsiyonel eylem butonu (or. "Egitime Git").
  // baglantiUrl http/https dogrulanir; baglantiMetni bos ise jenerik etiket.
  baglantiUrl   String?
  baglantiMetni String?
  tur        DuyuruTuru @default(bilgi)
  // "hepsi" | "satici" | "alici" (mevcut duyuru-gonder ile ayni; "hepsi" =
  // satici+alici, admin haric). Yayin aninda rol filtresine cevrilir.
  hedefKitle String
  // Yayin: taslak olarak kaydedilip sonra yayinlanabilir. yayinlandiMi true
  // olunca hedef kitleye Bildirim pointer'lari uretilmis demektir - IDEMPOTENT,
  // tekrar yayinlanamaz. gonderilenSayisi o an kac kisiye gittigi (istatistik);
  // okunan sayisi Bildirim.duyuruId + okunduMu ile canli sayilir.
  yayinlandiMi     Boolean   @default(false)
  yayinTarihi      DateTime?
  gonderilenSayisi Int       @default(0)
  olusturan   Kullanici @relation(fields: [olusturanId], references: [id])
  olusturanId String
  // Kalici silme YOK (proje ilkesi) - "yayindan kaldir" soft-delete eder;
  // detay sayfasi ve admin listesi silindiMi=false filtreler.
  silindiMi   Boolean   @default(false)
  createdAt         DateTime @default(now())
  guncellenmeZamani DateTime @updatedAt

  bildirimler Bildirim[]
}

// Magaza takibi: UrunFavori'den AYRI tablo - farkli varlik (Magaza, Urun degil),
// begeniMi karsiligi yok (sadece bildirim aboneligi, tek bayrak). Kullanici
// magazayi takip edince o magazaya YENI urun eklendiginde bildirim alir
// (urunEkle() basarili olduktan SONRA, route katmaninda tetiklenir - motor/lib
// fonksiyonu saf kalir, bkz. bildirim.ts deseni). takipMi: Boolean (silmek
// yerine false yapilir) - UrunFavori ile simetrik, "hicbir kayit kalici
// silinmez" ilkesiyle tutarli.
model MagazaTakip {
  id          String    @id @default(uuid())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId String
  magaza      Magaza    @relation(fields: [magazaId], references: [id])
  magazaId    String
  takipMi     Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([kullaniciId, magazaId])
}

// Degerlendirme/yorum: SADECE gercekten satin alanlar (Rezervasyon.durum=
// "satildi" VE aliciId=kullanici) birakabilir - bu kural DB'de ZORLANMAZ (FK
// ile "satin aldi mi" ifade edilemez), API route'unda (src/app/api/degerlendirme
// /route.ts) Rezervasyon.findFirst ile dogrulanir. Kullanici puanini/yorumunu
// SONRADAN guncelleyebilir - upsert (begeni/takip toggle'i gibi), tek satir
// (kullaniciId+urunId unique) - "hicbir kayit kalici silinmez" ilkesiyle
// tutarli: guncelleme = ayni satirin uzerine yazma, yeni satir degil. puan
// (1-5) DB seviyesinde kisitlanmaz - proje genelinde diger validasyonlar
// (fiyat>0, stok>=1) gibi SADECE API route'unda kontrol edilir.
model Degerlendirme {
  id                String    @id @default(uuid())
  kullanici         Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId       String
  urun              Urun      @relation(fields: [urunId], references: [id])
  urunId            String
  puan              Int
  yorum             String?
  // Admin moderasyon bayragi: Magaza.gizliMi ile AYNI desen. true ise vitrinde
  // (urun karti ozeti, tum-yorumlar sayfasi) gosterilmez ve ortalama puana
  // katilmaz; sahibi kendi degerlendirmesini (/degerlendirmelerim) HALA gorur.
  gizliMi           Boolean   @default(false)
  createdAt         DateTime  @default(now())
  guncellenmeZamani DateTime  @updatedAt

  @@unique([kullaniciId, urunId])
}

// Magaza-seviyesi degerlendirme/yorum: Degerlendirme (urun-seviyesi) ile AYNI
// desen (upsert, DB'de kisitlanmayan puan, hic hard-delete yok) ama AYRI tablo
// - Degerlendirme.urunId NOT NULL oldugu icin ayni tabloda tutmak urunId'yi
// nullable yapip Sikayet'teki hedefUrunId/hedefMagazaId XOR desenine gecmeyi
// gerektirirdi (zayif DB garantisi + her mevcut urun-degerlendirme sorgusunun
// gozden gecirilmesi). Kim degerlendirebilir: bu magazadan (HANGI urun olursa
// olsun) en az bir Rezervasyon.durum="satildi" kaydi olan herkes - kontrol API
// katmaninda (src/lib/magaza-degerlendirme.ts) Urun uzerinden dolayli join ile
// yapilir, DB'de zorlanmaz (Degerlendirme'deki ayni yaklasimla tutarli).
model MagazaDegerlendirme {
  id                String    @id @default(uuid())
  kullanici         Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId       String
  magaza            Magaza    @relation(fields: [magazaId], references: [id])
  magazaId          String
  puan              Int
  yorum             String?
  // Degerlendirme.gizliMi ile AYNI desen/gerekce.
  gizliMi           Boolean   @default(false)
  createdAt         DateTime  @default(now())
  guncellenmeZamani DateTime  @updatedAt

  @@unique([kullaniciId, magazaId])
}

// Tek satirlik "singleton" platform-geneli ayar tablosu (ayni find-or-create
// deseni, bkz. src/lib/platform-ayarlari.ts). Motor
// (rezervasyonOlustur/rezervasyonGeriAl, src/lib/rezervasyon.ts) bu degerleri
// HER cagrida kilit ONCESI okur - eskiden MAX_YEDEK/GUVENILIRLIK_ESIGI kod-ici
// sabitti, artik admin panelinden (/admin/ayarlar) degistirilebilir.
model PlatformAyarlari {
  id                String   @id @default("singleton")
  // guvenilirlikEsigi: UST USTE kac "gelmedi" yasagi tetikler (2026-07-10'dan
  // beri seri/ardisik sayim - "satildi" seriyi bozar, alicinin kendi vazgecmesi
  // notrdur; bkz. gelmediYasagiKontrolEt).
  guvenilirlikEsigi Int      @default(3)
  maxYedek          Int      @default(5)
  // Seri dolunca uygulanan yeni-rezervasyon yasaginin suresi (gun).
  yasakSuresiGun    Int      @default(7)
  guncellenmeZamani DateTime @updatedAt
}

// Faz 4 (CMS/gorunum yonetimi) - [[feedback_kutsal-kural-admin-muaf]] geregi
// admin icin sadelik kurali gecerli degil. Her (sayfa,tur) cifti icin TEK bir
// sabit satir var (kullanici "yeni modul instance'i olustur" degil, var olan
// blogun sirasini/gorunurlugunu/gorunum ayarlarini degistiriyor) - bu yuzden
// @@unique([sayfa, tur]), coklu instance yok. sayfa alani AYNI tabloyu birden
// fazla baglamda (anasayfa modulleri, magaza sayfasi Hero bilesenleri)
// kullanabilmek icin - siralama/reorder sorgulari HER ZAMAN ayni sayfa
// icinde kalir, farkli sayfalardaki turler birbirinin sira sayacini
// etkilemez. ayarlar (JSON) modul turune gore degisen alanlari tutar
// (kolonSayisi, sunumTipi, ogeSayisi) - haftalik_ritim veya magaza_hero_*
// gibi urun-izgarasi olmayan turlerde bos kalir. Ilk okuma varsayilanlari
// tohumlar (ayni "find-or-seed" deseni, liste versiyonu - bkz. src/lib/sayfa-modulu.ts).
enum SayfaModulSayfasi {
  anasayfa
  magaza_hero
}

enum SayfaModulTuru {
  haftalik_ritim
  yeni_urunler
  en_cok_begenilen
  magaza_listesi
  magaza_hero_whatsapp
  magaza_hero_kroki
  magaza_hero_puan
}

model SayfaModulu {
  id                String            @id @default(uuid())
  sayfa             SayfaModulSayfasi @default(anasayfa)
  tur               SayfaModulTuru
  sira              Int
  aktifMi           Boolean           @default(true)
  ayarlar           Json              @default("{}")
  guncellenmeZamani DateTime          @updatedAt

  @@unique([sayfa, tur])
}

// Anahtar-deger site icerigi (Hero metinleri/gorseli, ileride footer/SSS/
// Hakkimizda/KVKK - bkz. admin-paneli-genisletme-plani hafiza notu). Satir
// yoksa "ayarlanmamis" demektir - uygulama katmani (siteIcerikHaritasiGetir)
// varsayilan deger dondurur, PlatformAyarlari'nin aksine burada tek bir
// singleton yerine cok sayida bagimsiz anahtar var, o yuzden find-or-create
// yerine "harita + varsayilan fallback" deseni kullanilir.
model SiteIcerik {
  anahtar           String   @id
  deger             String
  guncellenmeZamani DateTime @updatedAt
}
